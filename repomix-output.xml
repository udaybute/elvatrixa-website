 *
 * @param faqs  Array of { question, answer } pairs
 */
export function faqSchema(faqs: { question: string; answer: string }[]) {
  return {
    '@context': 'https://schema.org',
    '@type':    'FAQPage',
    mainEntity: faqs.map(faq => ({
      '@type':          'Question',
      name:              faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
