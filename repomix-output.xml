/* ── PLAIN TEXT VERSION ───────────────────────────────────────── */
/*
 * Required fallback for email clients that don't render HTML.
 * Also used by spam filters to verify content matches HTML.
 */

function buildEmailText(data: {
  referenceId: string
  projectType: string
  budget:      string
  timeline:    string
  description: string
  name:        string
  email:       string
  company:     string
  country:     string
  phone:       string
}): string {
  return [
    `NEW PROJECT BRIEF — ${data.referenceId}`,
    `${'─'.repeat(50)}`,
    ``,
    `CLIENT`,
    `  Name:    ${data.name}`,
    `  Email:   ${data.email}`,
    `  Company: ${data.company || '—'}`,
    `  Country: ${data.country || '—'}`,
    `  Phone:   ${data.phone   || '—'}`,
    ``,
    `PROJECT`,
    `  Service:  ${data.projectType || '—'}`,
    `  Budget:   ${data.budget      || '—'}`,
    `  Timeline: ${data.timeline    || '—'}`,
    ``,
    data.description ? `BRIEF\n  ${data.description}\n` : '',
    `${'─'.repeat(50)}`,
    `Received: ${new Date().toLocaleString('en-GB', { dateStyle: 'full', timeStyle: 'short', timeZone: 'Europe/London' })}`,
    `Reply: mailto:${data.email}`,
  ].filter(Boolean).join('\n')
}


/* ── POST HANDLER ────────────────────────────────────────────── */

export async function POST(req: Request) {
  try {

    /* ── 1. Rate limit check ── */
    const forwarded = req.headers.get('x-forwarded-for')
    const ip        = forwarded?.split(',')[0]?.trim() ?? 'unknown'

    if (isRateLimited(ip)) {
      return NextResponse.json(
        {
          success: false,
          message: 'Too many submissions. Please try again in 15 minutes.',
        },
        { status: 429 },
      )
    }

    /* ── 2. Parse and sanitise body ── */
    const body = await req.json()

    const name        = sanitise(body.name)
    const email       = sanitise(body.email)
    const company     = sanitise(body.company)
    const country     = sanitise(body.country)
    const phone       = sanitise(body.phone)
    const projectType = sanitise(body.projectType)
    const budget      = sanitise(body.budget)
    const timeline    = sanitise(body.timeline)
    const description = sanitise(body.description)
    const gdprConsent = Boolean(body.gdprConsent)

    /* ── 3. Validate required fields ── */
    if (!name) {
      return NextResponse.json(
        { success: false, message: 'Name is required.' },
        { status: 400 },
      )
    }

    if (!email || !isValidEmail(email)) {
      return NextResponse.json(
        { success: false, message: 'A valid email address is required.' },
        { status: 400 },
      )
    }

    if (!gdprConsent) {
      return NextResponse.json(
        { success: false, message: 'GDPR consent is required.' },
        { status: 400 },
      )
    }

    /* ── 4. Generate reference ID ── */
    const referenceId = generateReferenceId()

    /* ── 5. Build email content ── */
    const emailData = {
      referenceId,
      projectType,
      budget,
      timeline,
      description,
      name,
      email,
      company,
      country,
      phone,
    }

    const subject = `New Brief: ${projectType || 'Project Enquiry'} — ${name} [${referenceId}]`

    /* ── 6. Send email via Resend ── */
    const { error: resendError } = await resend.emails.send({
      from:     FROM_ADDRESS,
      to:       [CONTACT_EMAIL],
      replyTo:  email,
      subject,
      html:     buildEmailHtml(emailData),
      text:     buildEmailText(emailData),
      tags: [
        { name: 'category',    value: 'contact-form'               },
        { name: 'service',     value: projectType || 'unspecified'  },
        { name: 'reference',   value: referenceId                   },
      ],
    })

    if (resendError) {
      console.error('[Contact API] Resend error:', resendError)
      return NextResponse.json(
        {
          success: false,
          message: 'Failed to send your brief. Please email us directly at hello@elvatrixa.com',
        },
        { status: 500 },
      )
    }

    /* ── 7. Success response ── */
    return NextResponse.json(
      {
        success:     true,
        message:     'Brief received successfully.',
        referenceId,
      },
      { status: 200 },
    )

  } catch (error) {
    console.error('[Contact API] Unexpected error:', error)

    return NextResponse.json(
      {
        success: false,
        message: 'An unexpected error occurred. Please email us directly at hello@elvatrixa.com',
      },
      { status: 500 },
    )
  }
}
